{
  "name": "warpgrid",
  "version": "0.0.1",
  "private": true,
  "description": "Warpgrid — bend a rigid DAW grid to match the flowing tempo of a human performance. Import audio/MIDI, detect beats, warp the grid by hand, export tempo maps.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "vite preview --host 0.0.0.0 --port 4173",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@tonejs/midi": "^2.0.28",
    "immer": "^10.1.1",
    "pako": "^2.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zundo": "^2.3.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/pako": "^2.0.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
